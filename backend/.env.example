# ── TigerGraph Local (Community Edition via Docker) ───────────────
TG_HOST=http://127.0.0.1
TG_USERNAME=tigergraph
TG_PASSWORD=tigergraph
TG_GRAPH=MedGraph
TG_RESTPP_PORT=9000
TG_GS_PORT=14240
TG_API_TOKEN=
TG_SECRET=

# ── MedGraph API Security ─────────────────────────────────────────
# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
MEDGRAPH_API_KEY=dev-insecure-key-change-me

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Dev flags ─────────────────────────────────────────────────────
# Set to true to return mock data when TigerGraph is offline (dev only)
USE_MOCK_DATA=false

# ── TigerGraph Cloud (optional) ───────────────────────────────────
# TG_HOST=https://<your-cloud-id>.i.tgcloud.io
# TG_PASSWORD=<cloud_password>
# TG_RESTPP_PORT=443
# TG_GS_PORT=443
